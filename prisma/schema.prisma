generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  candidate
  company
  admin
}

enum ApplicationStatus {
  pending
  reviewed
  accepted
  rejected
}

enum Industry {
  care
  healthcare
  it
  crafts
  logistics
  gastronomy
  administration
  education
  industry
  other
}

enum LanguageLevel {
  A1
  A2
  B1
  B2
  C1
  C2
  NATIVE
}

enum FacilityType {
  nursing_home
  hospital
  outpatient_care
  rehabilitation
  clinic
  staffing_agency
  other
}

enum DriverLicenseCategory {
  none
  B
  C
  D
  other
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  passwordHash     String?
  role             Role              @default(candidate)
  createdAt        DateTime          @default(now())
  candidateProfile CandidateProfile?
  company          Company?
  accounts         Account[]
  sessions         Session[]
}

model CandidateProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  phone                 String?
  city                  String?
  profession            String?
  skills                String[]
  cvUrl                 String?
  summary               String?
  profileImageUrl       String?
  germanLevel           LanguageLevel?
  desiredSalary         Int?
  availableFrom         DateTime?
  yearsOfExperience     Int?
  driverLicenseCategory DriverLicenseCategory @default(none)
  hasCar                Boolean               @default(false)
  willingToRelocate     Boolean               @default(false)
  willingToTravel       Boolean               @default(false)

  preferredIndustry Industry?

  expectedEmploymentType String?
  profileCompleted       Boolean @default(false)
  isAvailable            Boolean @default(true)

  applications    Application[]
  educations      Education[]
  workExperiences WorkExperience[]
  certificates    Certificate[]
  languages       Language[]

  createdAt DateTime @default(now())
}

model Education {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  degree       String
  institution  String
  fieldOfStudy String?

  city    String?
  country String?

  startDate DateTime?
  endDate   DateTime?

  currentlyStudying Boolean @default(false)

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkExperience {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  company  String
  position String

  city    String?
  country String?

  startDate DateTime?
  endDate   DateTime?

  currentlyWorking Boolean @default(false)

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certificate {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  title  String
  issuer String

  issueDate  DateTime?
  expiryDate DateTime?

  certificateNumber String?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  language String
  level    LanguageLevel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  address      String?
  city         String?
  phone        String?
  logoUrl      String?
  website      String?
  description  String?
  facilityType FacilityType?
  industry     Industry?
  isVerified   Boolean       @default(false)
  jobs         Job[]
  createdAt    DateTime      @default(now())
}

model Job {
  id                  String         @id @default(cuid())
  companyId           String
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title               String
  description         String
  city                String
  employmentType      String
  industry            Industry       @default(care)
  salaryFrom          Int?
  salaryTo            Int?
  requiredSkills      String[]
  requiredGermanLevel LanguageLevel?
  experienceRequired  Int?

  driverLicenseNeeded Boolean @default(false)
  carRequired         Boolean @default(false)

  shiftWork   Boolean @default(false)
  weekendWork Boolean @default(false)
  nightShift  Boolean @default(false)

  housingAvailable        Boolean @default(false)
  visaSupport             Boolean @default(false)
  internationalApplicants Boolean @default(false)

  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)

  applications Application[]
  createdAt    DateTime      @default(now())
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(pending)
  matchScore  Int?
  aiSummary   String?
  createdAt   DateTime          @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
